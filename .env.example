# IBM watsonx.ai Configuration
WATSONX_API_KEY=your_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Demo Mode Configuration
# Set to 'true' to use pre-generated demo fixtures for "The Last Bloom" story
# instead of calling the live AI API. Useful for:
# - Demonstrations when watsonx quota is exceeded
# - Testing the UI without consuming API tokens
# - Showcasing the system when API is unavailable
# Demo fixtures are located in src/data/demo/
PRISM_DEMO_MODE=false